{
    "name": "entertainment-tadka/bot",
    "description": "Advanced Telegram Movie Bot",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "ext-sqlite3": "*",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-fileinfo": "*",
        "ext-zip": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "scripts": {
        "post-install-cmd": [
            "chmod -R 755 storage/",
            "chmod 666 movies.csv",
            "chmod 666 *.json"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}